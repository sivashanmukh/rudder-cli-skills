# Claude Code local settings
# The root .claude/ is for local development, not for distribution
# Skills are published from the top-level skills/ directory
.claude/

# Example settings are in .claude/settings.example.json (tracked)
# User-specific settings should not be committed
examples/**/.claude/settings.local.json

# Build artifacts
dist/
build/
*.out

# Test artifacts
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp
